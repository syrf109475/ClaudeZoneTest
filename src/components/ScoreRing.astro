---
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const r = 52;
const circ = 2 * Math.PI * r;
---

<div class="gauge" id="detector">
  <div class="gauge__ring" id="score-gauge">
    <svg viewBox="0 0 120 120" aria-hidden="true">
      <circle class="gauge__track" cx="60" cy="60" r={r}></circle>
      <circle
        id="score-ring"
        cx="60"
        cy="60"
        r={r}
        style={`stroke-dasharray:${circ}px; stroke-dashoffset:${circ}px;`}></circle>
    </svg>
    <div class="gauge__center">
      <span class="gauge__num" id="score-value">0</span>
      <span class="gauge__outof">{t('hero.scoreOutOf')}</span>
    </div>
  </div>

  <span class="risk-badge" id="risk-badge">{t('scan.ready')}</span>
  <p class="risk-desc" id="risk-desc"></p>

  <div class="scan-actions">
    <button class="scan-btn" id="retest" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12a9 9 0 1 1-2.64-6.36M21 4v4h-4"></path>
      </svg>
      <span id="retest-label">{t('ui.start')}</span>
    </button>
    <button
      class="scan-save"
      id="share-save"
      type="button"
      hidden
      data-share="save"
      data-ga-event="share_click"
      data-ga-id="save"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><path d="M7 10l5 5 5-5"></path><path d="M12 15V3"></path></svg>
      <span id="share-save-label">{t('share.save')}</span>
    </button>
  </div>

  <ul class="trust">
    <li>{t('hero.badge.local')}</li>
    <li>{t('hero.badge.noUpload')}</li>
    <li>{t('hero.badge.openSource')}</li>
  </ul>
</div>
